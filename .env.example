# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Linear Configuration
LINEAR_API_KEY=lin_api_your-linear-api-key
LINEAR_COMPANY_SLUG=your-company

# OpenAI (optional, for Vision OCR)
OPENAI_API_KEY=sk-your-openai-api-key

# OCR Provider: easyocr | tesseract | vision
OCR_PROVIDER=easyocr

# App Settings
PORT=3000
LOG_LEVEL=INFO
SLACK_SOCKET_MODE=false

# Optional: Recent message count when /release is used outside a thread
FALLBACK_MESSAGE_COUNT=20
